        "https://www.gwtproject.org/doctype/2.10.0/gwt-module.dtd">
<module rename-to="proxyAdmin">
    <inherits name="com.google.gwt.user.User"/>
    <inherits name="com.google.gwt.user.theme.clean.Clean"/>
    <inherits name="io.github.connellite.proxy.client.rpc.Rpc"/>

    <entry-point class="io.github.connellite.proxy.client.ProxyAdminApp"/>

    <source path=""/>
